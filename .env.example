# Frontend
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
DATABASE_URL=postgresql://airscan:airscan@localhost:5432/airscan
REDIS_URL=redis://localhost:6379/0
CLERK_SECRET_KEY=
# Optional (recommended): strict JWT validation
CLERK_JWKS_URL=
CLERK_ISSUER=

OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_ENDPOINT_URL=
AWS_REGION=auto

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

FRONTEND_URL=http://localhost:3000

# ─── Beta / Tester Mode ─────────────────────────────────────────────────────
# Set BETA_MODE=true to disable ALL billing gates.
# Every signed-in user gets unlimited analyses for free.
# Perfect for demos, testers, and early NBC pilots.
BETA_MODE=true

# Comma-separated emails that auto-upgrade to beta plan on first login.
# Anyone NOT in this list but with BETA_MODE=true still gets unlimited access.
BETA_EMAILS=gabe@example.com,tester1@example.com,tester2@example.com
